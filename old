}

// ── SLOT MODAL ────────────────────────────────────────
function buildSlotModal(box, slot, isPast) {
  const subj = STATE.data.subjects.find(s => s.id === slot.subject) || STATE.data.subjects[0];

  const title = el('div', 'modal-title'); title.textContent = subj?.name || 'Lesson';
  const isLesson = slot.type === 'lesson' || subj?.isLesson;
  const sub = el('div', 'modal-subtitle');
  sub.textContent = slot.time + (isLesson ? ' · Online lesson' : (subj?.tool ? ' · ' + subj.tool : ''));
  box.appendChild(title); box.appendChild(sub);

  if (!isPast) {
    let localDone = slot.done;
    let localNote = slot.note || '';
    let localSubject = slot.subject;

    // Done toggle
    const doneBtn = el('button', `done-toggle-btn ${localDone ? 'done-on' : 'done-off'}`);
    doneBtn.textContent = localDone ? '✓ Done — tap to undo' : '○ Mark as done';
    doneBtn.addEventListener('click', () => {
      localDone = !localDone;
      doneBtn.className = `done-toggle-btn ${localDone ? 'done-on' : 'done-off'}`;
      doneBtn.textContent = localDone ? '✓ Done — tap to undo' : '○ Mark as done';
    });
    box.appendChild(doneBtn);

    // Subject selector
    const subjSel = el('select', 'form-select');
    STATE.data.subjects.forEach(s => {
      const opt = document.createElement('option');
      opt.value = s.id; opt.textContent = s.name;
      if (s.id === localSubject) opt.selected = true;
      subjSel.appendChild(opt);
    });
    subjSel.addEventListener('change', e => localSubject = e.target.value);
    box.appendChild(formGroup('Subject', subjSel));

    // Notes
    const noteTA = el('textarea', 'form-textarea');
    noteTA.placeholder = 'How did it go? e.g. Finished Tassomai chapter, struggled with equations…';
    noteTA.value = localNote;
    noteTA.addEventListener('input', e => localNote = e.target.value);
    box.appendChild(formGroup('📝 Notes', noteTA));

    // Buttons
    const btns = el('div', 'modal-btns');
    const removeBtn = btn('Remove slot', 'btn-danger', () => {
      if (confirm('Remove this lesson slot?')) {
        setData({ slots: STATE.data.slots.filter(s => s.id !== slot.id), modal: null });
        closeModal();
      }
    });
    const saveBtn = btn('Save', 'btn-primary', () => {
      setData({ slots: STATE.data.slots.map(s => s.id === slot.id ? {...s, done: localDone, note: localNote, subject: localSubject} : s) });
      closeModal();
    });
    btns.appendChild(removeBtn); btns.appendChild(saveBtn);
    box.appendChild(btns);

  } else {
    // Past week — read only
    const ro = el('div');
    ro.style.cssText = 'background:rgba(255,255,255,0.04);border-radius:10px;padding:11px 14px;font-size:13px;color:var(--text2);margin-bottom:10px';
    ro.textContent = '📖 Past week — this is read only.';
    box.appendChild(ro);

    if (slot.note) {
      const nb = el('div');
      nb.style.cssText = 'font-size:14px;color:var(--text);line-height:1.7;border-left:3px solid var(--accent);padding-left:12px;margin-bottom:14px';
      nb.textContent = slot.note;
      box.appendChild(nb);
    }

    const closeB = btn('Close', 'btn-primary btn-full', closeModal);
    box.appendChild(closeB);
  }
}

