function renderSlotCard(slot, isPast) {
  const subj = STATE.data.subjects.find(s => s.id === slot.subject) || STATE.data.subjects[0];
  const c = getColour(subj?.colour);
  const isLesson = slot.type === 'lesson' || subj?.isLesson;

  const card = el('div', `slot-card${slot.done ? ' is-done' : ''}${isPast ? ' is-past' : ''}${isLesson ? ' is-lesson' : ''}`);
  card.style.cssText = `background:${c.bg}; border-color:${c.border}; color:${c.hex}`;

  const bar = el('div', 'slot-accent-bar'); bar.style.background = c.hex;
  const tick = el('div', 'slot-tick'); tick.textContent = slot.done ? '✓' : '○';
  const name = el('div', 'slot-name'); name.textContent = subj?.name || 'Lesson';
  const time = el('div', 'slot-time');
  time.textContent = isLesson
    ? slot.time
    : slot.time + (subj?.tool ? ' · ' + subj.tool : '');

  // Badge: pulsing LIVE dot for online lessons, plain tag for revision
  let badge;
  if (isLesson) {
    badge = el('div', 'live-badge');
    const dot = el('div', 'live-dot');
    badge.appendChild(dot);
    badge.appendChild(document.createTextNode('Live'));
  } else {
    badge = el('div', 'revision-badge');
    badge.style.cssText = `background:${c.tag}; color:${c.hex}`;
    badge.textContent = subj?.tag || 'Revision';
  }

  card.appendChild(bar); card.appendChild(tick);
  card.appendChild(name); card.appendChild(time); card.appendChild(badge);

  if (slot.note) {
    const notePrev = el('div', 'slot-note-preview');
    notePrev.textContent = '📝 ' + slot.note;
    card.appendChild(notePrev);
  }

  card.addEventListener('click', () => openModal({ type: 'slot', slot: {...slot}, isPast }));
  return card;
}

