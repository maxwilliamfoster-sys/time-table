const uid = () => 'u'+Math.random().toString(36).slice(2)+Date.now().toString(36);

// ═══════════════════════════════════════════════════════
// STORAGE
// ═══════════════════════════════════════════════════════

function loadUserData(username) {
  try {
    const raw = localStorage.getItem('gcse_' + username);
    if (!raw) return null;
    return JSON.parse(raw);
  } catch { return null; }
}

function saveUserData(username, data) {
  try {
    localStorage.setItem('gcse_' + username, JSON.stringify(data));
  } catch(e) { console.error('Save failed:', e); }
}

function getKnownUsers() {
  try {
    return JSON.parse(localStorage.getItem('gcse_users') || '[]');
  } catch { return []; }
}

function addKnownUser(username) {
  const users = getKnownUsers();
  if (!users.includes(username)) {
    users.unshift(username);
    localStorage.setItem('gcse_users', JSON.stringify(users.slice(0, 5)));
  }
}

function loadBgImage() {
  try { return localStorage.getItem('gcse_bg_image') || null; } catch { return null; }
}
function saveBgImage(base64) {
  try { if (base64) localStorage.setItem('gcse_bg_image', base64); else localStorage.removeItem('gcse_bg_image'); } catch {}
}

function getDefaultData() {
  return {
    slots: DEFAULT_SLOTS.map(s => ({...s})),
    subjects: DEFAULT_SUBJECTS.map(s => ({...s})),
    history: [],
    theme: 'dark',
    weekLabel: '',
    bgType: 'solid',    // 'solid' | 'photo'
    bgColour: '#0d0d18',
  };
}

// ═══════════════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════════════

let STATE = {
  screen: 'login',       // 'login' | 'app'
  username: null,
  weekOffset: 0,
  modal: null,           // null | { type, ...data }
  showSettings: false,
  data: getDefaultData(),
  bgImageData: null,
};

function setData(patch, save = true) {
  Object.assign(STATE.data, patch);
  if (save && STATE.username) saveUserData(STATE.username, STATE.data);
  render();
}

function setState(patch) {
  Object.assign(STATE, patch);
  render();
}

function openModal(modal) { setState({ modal }); }
function closeModal() { setState({ modal: null }); }

// ═══════════════════════════════════════════════════════
// BACKGROUND
// ═══════════════════════════════════════════════════════

function applyBackground() {
  const bgLayer = document.getElementById('bgLayer');
  const bgOverlay = document.getElementById('bgOverlay');
  if (!bgLayer || !bgOverlay) return;

  const d = STATE.data;
  const theme = THEMES.find(t => t.id === d.theme) || THEMES[0];

  if (d.bgType === 'photo' && STATE.bgImageData) {
    bgLayer.style.backgroundImage = `url(${STATE.bgImageData})`;
    bgLayer.style.opacity = '1';
    bgOverlay.style.background = 'rgba(0,0,0,0.55)';
    document.documentElement.style.setProperty('--bg', 'transparent');
  } else {
    bgLayer.style.backgroundImage = 'none';
    bgLayer.style.opacity = '0';
    const col = d.bgColour || theme.bg;
    bgOverlay.style.background = col;
    document.documentElement.style.setProperty('--bg', col);
  }
}

function compressAndSetImage(file) {
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      const MAX = 1200;
      const ratio = Math.min(MAX / img.width, MAX / img.height, 1);
      canvas.width = img.width * ratio;
      canvas.height = img.height * ratio;
      canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);
      const compressed = canvas.toDataURL('image/jpeg', 0.65);
      STATE.bgImageData = compressed;
      saveBgImage(compressed);
      setData({ bgType: 'photo' });
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

// ═══════════════════════════════════════════════════════
// RENDER HELPERS
// ═══════════════════════════════════════════════════════

function el(tag, className = '') {
  const d = document.createElement(tag);
  if (className) d.className = className;
  return d;
}

function btn(text, classes, onClick) {
  const b = el('button', 'btn ' + classes);
  b.textContent = text;
  b.addEventListener('click', onClick);
  return b;
}

function formGroup(labelText, inputEl) {
  const g = el('div', 'form-group');
  const l = el('label', 'form-label');
  l.textContent = labelText;
  g.appendChild(l);
  g.appendChild(inputEl);
  return g;
}

// ═══════════════════════════════════════════════════════
// LOGIN SCREEN
// ═══════════════════════════════════════════════════════

function renderLogin() {
  const wrap = el('div', 'login-screen');
  const card = el('div', 'login-card');

  const logo = el('div', 'login-logo'); logo.textContent = 'GCSE Planner';
  const tag = el('p', 'login-tagline'); tag.textContent = 'Track your lessons, notes and progress.';
  card.appendChild(logo);
  card.appendChild(tag);

  const knownUsers = getKnownUsers();

  if (knownUsers.length > 0) {
    const welcomeLabel = el('div', 'form-label');
    welcomeLabel.textContent = 'Welcome back';
    welcomeLabel.style.textAlign = 'left';
    card.appendChild(welcomeLabel);

    knownUsers.forEach(name => {
      const chip = el('div', 'user-chip');
      const av = el('div', 'user-chip-avatar');
      av.textContent = name.slice(0,2).toUpperCase();
      const nm = el('div', 'user-chip-name'); nm.textContent = name;
      const chk = el('div', 'user-chip-check'); chk.textContent = '→';
      chip.appendChild(av); chip.appendChild(nm); chip.appendChild(chk);
      chip.addEventListener('click', () => doLogin(name));
      card.appendChild(chip);
    });

    const div = el('div', 'divider');
    const l1 = el('div', 'divider-line');
    const dt = el('div', 'divider-text'); dt.textContent = 'or sign in as someone new';
    const l2 = el('div', 'divider-line');
    div.appendChild(l1); div.appendChild(dt); div.appendChild(l2);
    card.appendChild(div);
  }

  const nameInput = el('input', 'form-input');
  nameInput.placeholder = 'Enter your name…';
  nameInput.autocomplete = 'off';
  card.appendChild(formGroup('Your name', nameInput));

  const signInBtn = btn('Start ›', 'btn-primary btn-full', () => {
    const name = nameInput.value.trim();
    if (!name) { nameInput.style.borderColor = '#f76a8c'; nameInput.focus(); return; }
    doLogin(name);
  });
  nameInput.addEventListener('keydown', e => { if (e.key === 'Enter') signInBtn.click(); });
  card.appendChild(signInBtn);

  const note = el('p', 'login-note');
  note.textContent = 'Your name is stored in your browser. Anyone using this device can access the app — no password needed.';
  card.appendChild(note);

  wrap.appendChild(card);
  return wrap;
}

function doLogin(username) {
  addKnownUser(username);
  const saved = loadUserData(username);
  const data = saved || getDefaultData();
  STATE.bgImageData = loadBgImage();
  STATE.username = username;
  STATE.data = data;
  STATE.screen = 'app';
  render();
}

// ═══════════════════════════════════════════════════════
// TOPBAR
// ═══════════════════════════════════════════════════════

function renderTopbar() {
  const isPast = STATE.weekOffset < 0;
  const wLabel = STATE.weekOffset === 0 ? 'This week' :
    STATE.weekOffset < 0 ? `${Math.abs(STATE.weekOffset)}w ago` : `+${STATE.weekOffset}w`;

  const bar = el('div', 'topbar');

  // Left: logo + week nav
  const left = el('div'); left.style.cssText = 'display:flex;align-items:center;gap:12px;min-width:0';
  const logo = el('div', 'logo'); logo.textContent = 'GCSE';
  const nav = el('div', 'week-nav');
  const prevBtn = el('button', 'wnbtn'); prevBtn.textContent = '‹';
  prevBtn.addEventListener('click', () => setState({ weekOffset: STATE.weekOffset - 1, modal: null }));
  const wl = el('span', 'week-label'); wl.textContent = wLabel;
  const nextBtn = el('button', 'wnbtn'); nextBtn.textContent = '›';
  if (!isPast) nextBtn.disabled = true;
  nextBtn.addEventListener('click', () => { if (isPast) setState({ weekOffset: STATE.weekOffset + 1, modal: null }); });
  nav.appendChild(prevBtn); nav.appendChild(wl); nav.appendChild(nextBtn);
  left.appendChild(logo); left.appendChild(nav);

  // Right: clock, sync, settings, avatar
  const right = el('div', 'top-right');

  // Live GMT clock
  const clockWrap = el('div', 'clock-wrap');
  const clockTime = el('div', 'clock-time'); clockTime.id = 'live-clock';
  const clockLabel = el('div', 'clock-label'); clockLabel.textContent = 'GMT';
  clockWrap.appendChild(clockTime); clockWrap.appendChild(clockLabel);
  updateClock(); // set immediately
  right.appendChild(clockWrap);

  const syncBtn = el('button', 'icon-btn'); syncBtn.textContent = '⇄ Sync';
  syncBtn.addEventListener('click', () => openModal({ type: 'sync' }));

  const settBtn = el('button', 'icon-btn'); settBtn.textContent = '⚙';
  settBtn.addEventListener('click', () => setState({ showSettings: true }));

  const av = el('div', 'avatar-btn');
  av.title = `Signed in as ${STATE.username} — click to switch`;
  av.textContent = STATE.username.slice(0,2).toUpperCase();
  av.addEventListener('click', () => {
    if (confirm(`Sign out of "${STATE.username}"?`)) {
      setState({ screen: 'login', username: null, weekOffset: 0, modal: null, showSettings: false });
    }
  });

  right.appendChild(syncBtn); right.appendChild(settBtn); right.appendChild(av);
  bar.appendChild(left); bar.appendChild(right);
  return bar;
}

// ═══════════════════════════════════════════════════════
// MAIN
// ═══════════════════════════════════════════════════════

function renderMain() {
  const isPast = STATE.weekOffset < 0;
  const displaySlots = isPast
    ? (STATE.data.history.find(h => h.offset === STATE.weekOffset)?.slots || [])
    : STATE.data.slots;

  const total = displaySlots.length;
  const done = displaySlots.filter(s => s.done).length;
  const pct = total ? Math.round(done / total * 100) : 0;

  const main = el('div', 'main');

  // Progress
  const pc = el('div', 'prog-card');
  pc.innerHTML = `
    <div class="prog-label">Week: <strong>${done}/${total}</strong> done</div>
    <div class="prog-track"><div class="prog-fill" style="width:${pct}%"></div></div>
    <div class="prog-pct">${pct}%</div>`;
  main.appendChild(pc);

  // Next up card (current week only)
  if (!isPast) {
    const nextUp = buildNextUpCard();
    if (nextUp) main.appendChild(nextUp);
  }

  // Legend
  const legend = el('div');
  legend.style.cssText = 'display:flex;gap:14px;align-items:center;margin-bottom:14px;flex-wrap:wrap;padding:0 2px';
