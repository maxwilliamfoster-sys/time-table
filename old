<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>GCSE Planner</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
/* ─── RESET & BASE ─────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #0d0d18;
  --glass: rgba(18,18,32,0.88);
  --card: rgba(22,22,38,0.95);
  --card2: rgba(28,28,48,0.9);
  --border: rgba(255,255,255,0.08);
  --border2: rgba(255,255,255,0.14);
  --text: #f0f0fa;
  --text2: #a0a0c0;
  --text3: #606080;
  --accent: #7c6af7;
  --accent2: #f472b6;
  --green: #4ecdc4;
  --yellow: #f7c948;
  --r: 14px;
  --r2: 10px;
}
body {
  font-family: 'Outfit', sans-serif;
  font-size: 15px;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
.bg-layer {
  position: fixed; inset: 0; z-index: 0;
  background-size: cover; background-position: center; background-repeat: no-repeat;
  transition: opacity 0.4s;
}
.bg-overlay {
  position: fixed; inset: 0; z-index: 1;
  background: var(--bg);
  transition: opacity 0.4s;
}
#root { position: relative; z-index: 2; }

/* ─── ANIMATIONS ────────────────────────────────────── */
@keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:none; } }
@keyframes scaleIn { from { opacity:0; transform:scale(0.93); } to { opacity:1; transform:scale(1); } }
@keyframes slideRight { from { transform:translateX(100%); } to { transform:translateX(0); } }
@keyframes spin { to { transform: rotate(360deg); } }

/* ─── TOPBAR ─────────────────────────────────────────── */
.topbar {
  position: sticky; top: 0; z-index: 100;
  background: var(--glass);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(20px) saturate(1.4);
  -webkit-backdrop-filter: blur(20px) saturate(1.4);
  padding: 0 20px; height: 60px;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.logo {
  font-family: 'Syne', sans-serif; font-weight: 800; font-size: 20px;
  letter-spacing: -0.5px;
  background: linear-gradient(135deg, #a89cf7 0%, #f472b6 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; flex-shrink: 0;
}
.week-nav { display: flex; align-items: center; gap: 6px; }
.wnbtn {
  background: rgba(255,255,255,0.06); border: 1px solid var(--border);
  border-radius: 8px; padding: 6px 13px; cursor: pointer;
  font-size: 16px; font-weight: 600; color: var(--text2);
  font-family: 'Outfit', sans-serif; transition: all 0.15s; line-height: 1;
}
.wnbtn:hover { background: rgba(124,106,247,0.15); border-color: var(--accent); color: var(--accent); }
.wnbtn:disabled { opacity: 0.25; cursor: default; pointer-events: none; }
.week-label {
  font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700;
  color: var(--text); min-width: 100px; text-align: center;
}
.top-right { display: flex; align-items: center; gap: 8px; }
.icon-btn {
  background: rgba(255,255,255,0.06); border: 1px solid var(--border);
  border-radius: 9px; padding: 7px 13px; cursor: pointer;
  font-size: 14px; font-weight: 500; color: var(--text2);
  font-family: 'Outfit', sans-serif; transition: all 0.15s; display: flex; align-items: center; gap: 6px;
}
.icon-btn:hover { border-color: var(--accent); color: var(--text); background: rgba(124,106,247,0.1); }
.avatar-btn {
  width: 36px; height: 36px; border-radius: 50%;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  border: 2px solid transparent; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700; color: #fff;
  transition: border-color 0.15s; overflow: hidden; flex-shrink: 0;
}
.avatar-btn:hover { border-color: rgba(255,255,255,0.4); }
.avatar-btn img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }

/* ─── MAIN CONTENT ───────────────────────────────────── */
.main { padding: 20px 18px 100px; max-width: 1200px; margin: 0 auto; }

/* ─── GMT CLOCK ──────────────────────────────────────── */
.clock-wrap {
  display: flex; flex-direction: column; align-items: flex-end; flex-shrink: 0;
}
.clock-time {
  font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 800;
  letter-spacing: 0.04em; color: var(--text); line-height: 1;
}
.clock-label {
  font-size: 10px; font-weight: 600; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--text3); margin-top: 2px;
}
@media (max-width: 480px) { .clock-time { font-size: 14px; } }

/* ─── NEXT UP CARD ───────────────────────────────────── */
.next-up-card {
  border-radius: var(--r); padding: 14px 18px; margin-bottom: 14px;
  display: flex; align-items: center; gap: 14px;
  border: 1px solid var(--border); background: var(--card);
  animation: fadeUp 0.3s ease 0.05s both;
}
.next-up-left { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.next-up-eyebrow {
  font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--text3);
}
.next-up-title {
  font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 800;
  color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.next-up-meta { font-size: 12px; color: var(--text2); margin-top: 1px; }
.next-up-countdown {
  flex-shrink: 0; text-align: right;
  font-family: 'Syne', sans-serif;
}
.countdown-num {
  font-size: 22px; font-weight: 800; line-height: 1;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.countdown-label { font-size: 10px; color: var(--text3); font-weight: 600; margin-top: 2px; letter-spacing: 0.05em; }
.next-up-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.next-up-now {
  background: rgba(78,205,196,0.12); border-color: rgba(78,205,196,0.3);
}
.now-badge {
  background: rgba(78,205,196,0.15); border: 1px solid rgba(78,205,196,0.3);
  color: #4ecdc4; font-size: 11px; font-weight: 700; letter-spacing: 0.06em;
  text-transform: uppercase; padding: 4px 10px; border-radius: 6px;
  animation: livepulse 1.6s ease-in-out infinite; flex-shrink: 0;
}

/* ─── PROGRESS CARD ─────────────────────────────────── */
.prog-card {
  background: var(--card); border: 1px solid var(--border); border-radius: var(--r);
  padding: 14px 20px; margin-bottom: 16px;
  display: flex; align-items: center; gap: 16px;
  animation: fadeUp 0.3s ease both;
}
.prog-label { font-size: 13px; color: var(--text2); font-weight: 500; white-space: nowrap; }
.prog-label strong { color: var(--text); font-weight: 700; }
.prog-track {
  flex: 1; height: 7px; background: rgba(255,255,255,0.07);
  border-radius: 99px; overflow: hidden;
}
.prog-fill {
  height: 100%; border-radius: 99px;
  background: linear-gradient(90deg, var(--accent), var(--accent2));
  transition: width 0.6s cubic-bezier(0.34,1.56,0.64,1);
}
.prog-pct {
  font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  min-width: 42px; text-align: right;
}

/* ─── PAST BANNER ───────────────────────────────────── */
.past-banner {
  background: rgba(247,156,72,0.1); border: 1px solid rgba(247,156,72,0.25);
  border-radius: var(--r2); padding: 10px 16px; margin-bottom: 14px;
  font-size: 13px; font-weight: 500; color: #f79c48;
}

/* ─── DAYS GRID ─────────────────────────────────────── */
.days-grid {
  display: grid; grid-template-columns: repeat(5, 1fr);
  gap: 10px; margin-bottom: 16px;
}
@media (max-width: 900px) { .days-grid { grid-template-columns: repeat(3, 1fr); } }
@media (max-width: 580px) { .days-grid { grid-template-columns: 1fr 1fr; } }

.day-col { display: flex; flex-direction: column; }
.day-header {
  background: var(--card2); border: 1px solid var(--border); border-bottom: none;
  border-radius: var(--r) var(--r) 0 0; padding: 10px 14px; text-align: center;
}
.day-name {
  font-family: 'Syne', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3);
}
.day-body {
  background: var(--card); border: 1px solid var(--border);
  border-top: 2px solid var(--border2);
  border-radius: 0 0 var(--r) var(--r);
  padding: 8px; display: flex; flex-direction: column; gap: 7px;
  flex: 1; min-height: 180px;
}

/* ─── SLOT CARDS ─────────────────────────────────────── */
.slot-card {
  border-radius: var(--r2); padding: 10px 11px 9px;
  cursor: pointer; position: relative; overflow: hidden;
  border: 1.5px solid transparent;
  transition: transform 0.13s ease, box-shadow 0.13s ease;
}
.slot-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.35); }
.slot-card:active { transform: scale(0.97); }
.slot-card.is-done { opacity: 0.38; filter: saturate(0.12); }
.slot-card.is-done .slot-name { text-decoration: line-through; text-decoration-thickness: 1.5px; }
.slot-card.is-past { cursor: default; }
.slot-card.is-past:hover { transform: none; box-shadow: none; }
.slot-accent-bar { position: absolute; left: 0; top: 0; bottom: 0; width: 3.5px; border-radius: 3px 0 0 3px; }
.slot-tick {
  position: absolute; top: 8px; right: 8px;
  width: 17px; height: 17px; border-radius: 50%;
  border: 1.5px solid currentColor; opacity: 0.25;
  display: flex; align-items: center; justify-content: center;
  font-size: 9px; font-weight: 700; transition: all 0.2s;
}
.slot-card.is-done .slot-tick { opacity: 1; background: currentColor; color: #0d0d18; }
.slot-name {
  font-family: 'Syne', sans-serif; font-size: 12px; font-weight: 700;
  padding-left: 8px; line-height: 1.3; padding-right: 22px;
}
.slot-time { font-size: 11px; padding-left: 8px; opacity: 0.55; margin-top: 2px; }
.slot-tag {
  display: inline-block; font-size: 9px; font-weight: 700;
  letter-spacing: 0.07em; text-transform: uppercase;
  padding: 2px 7px; border-radius: 4px; margin-top: 5px; margin-left: 8px;
}
.slot-note-preview {
  font-size: 10px; padding-left: 8px; opacity: 0.5;
  margin-top: 3px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
/* Live lesson vs revision distinction */
.slot-card.is-lesson { border-left-width: 4px; }
.live-badge {
  display: inline-flex; align-items: center; gap: 4px;
  font-size: 9px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
  padding: 2px 8px 2px 5px; border-radius: 4px; margin-top: 5px; margin-left: 8px;
  background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.9);
}
.live-dot {
  width: 5px; height: 5px; border-radius: 50%; background: #fff; flex-shrink: 0;
  animation: livepulse 1.6s ease-in-out infinite;
}
@keyframes livepulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.35;transform:scale(0.65)} }
.revision-badge {
  display: inline-block; font-size: 9px; font-weight: 700;
  letter-spacing: 0.07em; text-transform: uppercase;
  padding: 2px 7px; border-radius: 4px; margin-top: 5px; margin-left: 8px;
}
.add-slot-btn {
  border-radius: var(--r2); padding: 10px;
  cursor: pointer; border: 1.5px dashed rgba(124,106,247,0.3);
  display: flex; align-items: center; justify-content: center; gap: 6px;
  color: var(--accent); font-size: 13px; font-weight: 600;
  opacity: 0.5; min-height: 50px; transition: all 0.15s;
  font-family: 'Outfit', sans-serif;
}
.add-slot-btn:hover { opacity: 1; border-color: var(--accent); background: rgba(124,106,247,0.07); transform: translateY(-1px); }

/* ─── ACTIONS ROW ───────────────────────────────────── */
.actions-row {
  display: flex; gap: 8px; align-items: center; flex-wrap: wrap; margin-bottom: 24px;
}
.week-name-input {
  flex: 1; min-width: 180px; padding: 11px 14px;
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--r2); color: var(--text); font-size: 14px;
  font-family: 'Outfit', sans-serif; outline: none; transition: border-color 0.15s;
}
.week-name-input:focus { border-color: var(--accent); }
.week-name-input::placeholder { color: var(--text3); }

/* ─── BUTTONS ────────────────────────────────────────── */
.btn {
  border-radius: var(--r2); padding: 10px 18px; font-size: 13px; font-weight: 600;
  cursor: pointer; font-family: 'Outfit', sans-serif;
  transition: all 0.15s; border: none; white-space: nowrap; display: inline-flex;
  align-items: center; gap: 6px;
}
.btn-primary {
  background: linear-gradient(135deg, var(--accent), #9f8fff); color: #fff;
}
.btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
.btn-ghost {
  background: rgba(255,255,255,0.06); border: 1px solid var(--border);
  color: var(--text2);
}
.btn-ghost:hover { border-color: var(--accent2); color: var(--accent2); background: rgba(244,114,182,0.07); }
.btn-danger {
  background: rgba(247,106,140,0.1); border: 1px solid rgba(247,106,140,0.25); color: #f76a8c;
}
.btn-danger:hover { background: rgba(247,106,140,0.2); }
.btn-full { width: 100%; justify-content: center; }

/* ─── HISTORY ────────────────────────────────────────── */
.history-section { margin-top: 8px; }
.section-title {
  font-family: 'Syne', sans-serif; font-size: 16px; font-weight: 700;
  color: var(--text); margin-bottom: 12px;
}
.history-list { display: flex; flex-direction: column; gap: 8px; }
.history-card {
  background: var(--card); border: 1px solid var(--border);
  border-radius: var(--r); padding: 14px 16px;
}
.history-card-top {
  display: flex; justify-content: space-between; align-items: flex-start;
  gap: 10px; margin-bottom: 8px;
}
.history-name { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: var(--text); }
.history-meta { font-size: 12px; color: var(--text3); margin-top: 2px; }
.history-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
.history-pct {
  font-family: 'Syne', sans-serif; font-size: 18px; font-weight: 800;
  background: linear-gradient(135deg, var(--accent), var(--accent2));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.history-bar-track { height: 4px; background: rgba(255,255,255,0.07); border-radius: 99px; overflow: hidden; }
.history-bar-fill { height: 100%; border-radius: 99px; background: linear-gradient(90deg, var(--accent), var(--accent2)); }
.small-btn {
  background: rgba(255,255,255,0.06); border: 1px solid var(--border);
  border-radius: 7px; padding: 4px 11px; font-size: 12px; font-weight: 600;
  color: var(--text2); cursor: pointer; font-family: 'Outfit', sans-serif; transition: all 0.15s;
}
.small-btn:hover { border-color: var(--accent); color: var(--accent); }
.del-btn {
  background: none; border: none; color: var(--text3); cursor: pointer;
  font-size: 15px; padding: 3px 6px; border-radius: 5px; transition: color 0.15s;
}
.del-btn:hover { color: #f76a8c; }

/* ─── MODAL OVERLAY ─────────────────────────────────── */
.modal-overlay {
  position: fixed; inset: 0; z-index: 500;
  background: rgba(0,0,0,0.75); backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  display: flex; align-items: center; justify-content: center; padding: 16px;
}
.modal-box {
  background: var(--card); border: 1px solid var(--border2);
  border-radius: 18px; padding: 26px; width: min(460px, 100%);
  max-height: 90vh; overflow-y: auto; position: relative;
  animation: scaleIn 0.18s cubic-bezier(0.34,1.56,0.64,1) both;
}
.modal-close-btn {
  position: absolute; top: 14px; right: 16px;
  background: rgba(255,255,255,0.07); border: 1px solid var(--border);
  border-radius: 8px; width: 32px; height: 32px;
  cursor: pointer; color: var(--text2); font-size: 16px;
  display: flex; align-items: center; justify-content: center;
  transition: all 0.15s; flex-shrink: 0;
}
.modal-close-btn:hover { background: rgba(247,106,140,0.15); border-color: #f76a8c; color: #f76a8c; }
.modal-title {
  font-family: 'Syne', sans-serif; font-size: 19px; font-weight: 800;
  color: var(--text); margin-bottom: 4px; padding-right: 40px;
}
.modal-subtitle { font-size: 13px; color: var(--text2); margin-bottom: 20px; }

/* ─── FORM ELEMENTS ─────────────────────────────────── */
.form-group { margin-bottom: 14px; }
.form-label {
  display: block; font-size: 11px; font-weight: 600;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--text3); margin-bottom: 6px;
}
.form-input, .form-select, .form-textarea {
  width: 100%; padding: 11px 13px;
  background: rgba(255,255,255,0.05); border: 1px solid var(--border2);
  border-radius: var(--r2); color: var(--text); font-size: 14px;
  font-family: 'Outfit', sans-serif; outline: none; transition: border-color 0.15s;
  -webkit-appearance: none; appearance: none;
}
.form-input:focus, .form-select:focus, .form-textarea:focus { border-color: var(--accent); background: rgba(255,255,255,0.07); }
.form-input::placeholder { color: var(--text3); }
.form-textarea { resize: vertical; min-height: 85px; line-height: 1.55; }
.form-select option { background: #181828; }
.modal-btns { display: flex; gap: 9px; margin-top: 18px; }
.modal-btns .btn { flex: 1; }

/* DONE TOGGLE */
.done-toggle-btn {
  width: 100%; padding: 11px 14px; border-radius: var(--r2); cursor: pointer;
  font-family: 'Syne', sans-serif; font-size: 13px; font-weight: 700;
  letter-spacing: 0.04em; text-transform: uppercase; transition: all 0.15s;
  border: 1.5px solid; margin-bottom: 14px;
}
.done-off { background: rgba(124,106,247,0.08); color: var(--accent); border-color: rgba(124,106,247,0.25); }
.done-on  { background: rgba(78,205,196,0.12); color: #4ecdc4; border-color: rgba(78,205,196,0.3); }

/* ─── COLOUR SWATCHES ───────────────────────────────── */
.swatch-row { display: flex; gap: 8px; flex-wrap: wrap; }
.swatch {
  width: 26px; height: 26px; border-radius: 50%; cursor: pointer;
  border: 2.5px solid transparent; transition: transform 0.12s;
  flex-shrink: 0;
}
.swatch:hover { transform: scale(1.18); }
.swatch.active { border-color: #fff; transform: scale(1.22); }

/* ─── SETTINGS PANEL ────────────────────────────────── */
.settings-wrap { position: fixed; inset: 0; z-index: 400; display: flex; justify-content: flex-end; }
.settings-backdrop { position: absolute; inset: 0; background: rgba(0,0,0,0.55); }
.settings-panel {
  position: relative; z-index: 1; width: min(340px, 95vw);
  background: var(--card); border-left: 1px solid var(--border2);
  height: 100%; overflow-y: auto; padding: 24px;
  animation: slideRight 0.2s ease-out both;
}
.settings-header {
  font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 800;
  color: var(--text); padding-bottom: 16px; border-bottom: 1px solid var(--border);
  margin-bottom: 20px; display: flex; justify-content: space-between; align-items: center;
}
.settings-section { margin-bottom: 24px; }
.settings-section-label {
  font-size: 11px; font-weight: 700; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--text3); margin-bottom: 12px;
}

/* THEME GRID */
.theme-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 8px; }
.theme-tile {
  border: 1.5px solid var(--border); border-radius: 10px; padding: 8px 6px;
  cursor: pointer; text-align: center; background: transparent; transition: all 0.15s;
}
.theme-tile:hover { border-color: var(--accent); }
.theme-tile.active { border-color: var(--accent); background: rgba(124,106,247,0.1); }
.theme-preview { height: 22px; border-radius: 5px; margin-bottom: 5px; }
.theme-name { font-size: 11px; font-weight: 600; color: var(--text); }

/* SUBJECT LIST */
.subject-list { display: flex; flex-direction: column; gap: 6px; }
.subject-row {
  display: flex; align-items: center; gap: 9px;
  background: rgba(255,255,255,0.04); border: 1px solid var(--border);
  border-radius: var(--r2); padding: 9px 11px;
}
.subject-dot { width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0; }
.subject-name { flex: 1; font-size: 13px; color: var(--text); font-weight: 500; }
.subject-tool { font-size: 11px; color: var(--text3); }
.subject-del {
  background: none; border: none; color: var(--text3); cursor: pointer;
  font-size: 14px; padding: 2px 5px; border-radius: 4px; transition: color 0.15s;
}
.subject-del:hover { color: #f76a8c; }
.add-subject-row { display: flex; gap: 6px; margin-top: 9px; align-items: center; }
.add-subject-row .form-input { margin-bottom: 0; font-size: 13px; padding: 8px 11px; }

/* BACKGROUND OPTIONS */
