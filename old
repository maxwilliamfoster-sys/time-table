// ═══════════════════════════════════════════════════════
// TIME HELPERS + CLOCK + NEXT UP
// ═══════════════════════════════════════════════════════

function timeToMins(t) {
  // handles "9:45", "11:00", "14:15" etc.
  const parts = t.split(':');
  return parseInt(parts[0], 10) * 60 + parseInt(parts[1] || '0', 10);
}

function gmtNowMins() {
  const now = new Date();
  return now.getUTCHours() * 60 + now.getUTCMinutes();
}

function gmtDayIndex() {
  // 0=Mon ... 4=Fri, returns -1 on Sat/Sun
  const d = new Date().getUTCDay(); // 0=Sun,1=Mon...6=Sat
  if (d === 0 || d === 6) return -1;
  return d - 1;
}

function updateClock() {
  const el2 = document.getElementById('live-clock');
  if (!el2) return;
  const now = new Date();
  const h = String(now.getUTCHours()).padStart(2, '0');
  const m = String(now.getUTCMinutes()).padStart(2, '0');
  const s = String(now.getUTCSeconds()).padStart(2, '0');
  el2.textContent = `${h}:${m}:${s}`;
}

// Start clock ticker — runs every second, only updates the text node, no re-render
let clockInterval = null;
function startClock() {
  if (clockInterval) clearInterval(clockInterval);
  clockInterval = setInterval(() => {
    updateClock();
    // Also refresh next-up card every minute
    const nextUpEl = document.getElementById('next-up-card');
    if (nextUpEl) {
      const fresh = buildNextUpCard();
      if (fresh) nextUpEl.replaceWith(fresh);
      else nextUpEl.remove();
    }
  }, 1000);
}

function buildNextUpCard() {
  if (STATE.weekOffset !== 0) return null; // only show on current week

  const nowMins = gmtNowMins();
  const todayIdx = gmtDayIndex();
  const allSlots = STATE.data.slots;

  // Collect all slots for today AND future days this week, with computed mins
  let candidates = [];
  for (let di = Math.max(todayIdx, 0); di < 5; di++) {
    const daySlots = allSlots
      .filter(s => s.day === di)
      .map(s => ({ ...s, mins: timeToMins(s.time) }))
      .sort((a, b) => a.mins - b.mins);
    daySlots.forEach(s => candidates.push({ ...s, di }));
  }

  // Find: currently happening (within 45-min window) OR next upcoming
  let current = null, upcoming = null;

  if (todayIdx >= 0) {
    const todaySlots = candidates.filter(s => s.di === todayIdx);
    current = todaySlots.find(s => s.mins <= nowMins && nowMins < s.mins + 45 && !s.done) || null;
    upcoming = candidates.find(s => {
      if (s.di === todayIdx) return s.mins > nowMins && !s.done;
      return s.di > todayIdx && !s.done;
    }) || null;
  } else {
    // Weekend — show first slot of Monday
    upcoming = candidates.find(s => !s.done) || null;
  }

  const target = current || upcoming;
  if (!target) return null;

  const subj = STATE.data.subjects.find(s => s.id === target.subject) || STATE.data.subjects[0];
  const c = getColour(subj?.colour);
  const isLesson = target.type === 'lesson' || subj?.isLesson;
  const isNow = !!current;

  const card = el('div', `next-up-card${isNow ? ' next-up-now' : ''}`);
  card.id = 'next-up-card';
  if (isNow) card.style.borderColor = 'rgba(78,205,196,0.3)';

  // Colour dot
  const dot = el('div', 'next-up-dot');
  dot.style.background = c.hex;
  card.appendChild(dot);

  // Info
  const info = el('div', 'next-up-left');
  const eyebrow = el('div', 'next-up-eyebrow');
  const dayNames = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
  const targetDay = target.di === todayIdx ? 'Today' : dayNames[target.di];
  eyebrow.textContent = isNow ? '▶ Happening now' : `Coming up · ${targetDay}`;

  const title = el('div', 'next-up-title');
  title.style.color = c.hex;
  title.textContent = subj?.name || 'Lesson';

  const meta = el('div', 'next-up-meta');
  meta.textContent = target.time + (isLesson ? ' · Online lesson' : (subj?.tool ? ' · ' + subj.tool : ''));

  info.appendChild(eyebrow); info.appendChild(title); info.appendChild(meta);
  card.appendChild(info);

  // Right side
  const right2 = el('div', 'next-up-countdown');
  if (isNow) {
    const badge = el('div', 'now-badge'); badge.textContent = 'Now';
    right2.appendChild(badge);
  } else if (target.di === todayIdx) {
    const diffMins = target.mins - nowMins;
    const hrs = Math.floor(diffMins / 60);
    const mins = diffMins % 60;
    const num = el('div', 'countdown-num');
    num.textContent = hrs > 0 ? `${hrs}h ${mins}m` : `${mins}m`;
    const lbl = el('div', 'countdown-label'); lbl.textContent = 'until start';
    right2.appendChild(num); right2.appendChild(lbl);
  } else {
    const num = el('div', 'countdown-num'); num.textContent = targetDay.slice(0,3);
    const lbl = el('div', 'countdown-label'); lbl.textContent = target.time;
    right2.appendChild(num); right2.appendChild(lbl);
  }
  card.appendChild(right2);
  return card;
}

// ─── BOOT ─────────────────────────────────────────────
STATE.bgImageData = loadBgImage();
render();
startClock();
</script>
