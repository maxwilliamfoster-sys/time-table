// ── SYNC MODAL ────────────────────────────────────────
function buildSyncModal(box) {
  const title = el('div', 'modal-title'); title.textContent = '⇄ Sync between devices';
  const sub = el('div', 'modal-subtitle'); sub.textContent = 'Move your data between your laptop and iPhone';
  box.appendChild(title); box.appendChild(sub);

  const info = el('div', 'info-box');
  info.innerHTML = '<strong>How it works:</strong> tap <em>Copy code</em> on one device, then open the app on your other device and paste it into the restore box.';
  box.appendChild(info);

  // Export
  const exportBtn = btn('📋 Copy backup code', 'btn-primary btn-full', () => {
    const code = btoa(unescape(encodeURIComponent(JSON.stringify({
      slots: STATE.data.slots, subjects: STATE.data.subjects,
      history: STATE.data.history, theme: STATE.data.theme,
      weekLabel: STATE.data.weekLabel,
    }))));
    if (navigator.clipboard?.writeText) {
      navigator.clipboard.writeText(code).then(() => {
        exportBtn.textContent = '✓ Copied to clipboard!';
        setTimeout(() => exportBtn.textContent = '📋 Copy backup code', 2500);
      });
    } else {
      const cd = el('div', 'code-display'); cd.textContent = code;
      box.insertBefore(cd, importSection);
    }
  });
  exportBtn.style.marginBottom = '12px';
  box.appendChild(exportBtn);

  // Import
  const importSection = el('div');
  const importLabel = el('div', 'form-label'); importLabel.textContent = 'Or paste a backup code to restore:';
  const importTA = el('textarea', 'form-textarea'); importTA.placeholder = 'Paste your backup code here…';
  importTA.style.minHeight = '60px'; importTA.style.fontFamily = 'monospace'; importTA.style.fontSize = '11px';
  const restoreBtn = btn('↓ Restore from code', 'btn-ghost btn-full', () => {
    try {
      const d = JSON.parse(decodeURIComponent(escape(atob(importTA.value.trim()))));
      if (!d.slots) throw new Error('Invalid');
      if (!confirm('This replaces all your current data. Continue?')) return;
      setData({ slots: d.slots, subjects: d.subjects || STATE.data.subjects,
        history: d.history || [], theme: d.theme || 'dark', weekLabel: d.weekLabel || '' });
      closeModal();
      alert('✓ Data restored!');
    } catch { alert('Invalid code — make sure you copied the whole thing.'); }
  });
  restoreBtn.style.marginTop = '8px';
  importSection.appendChild(importLabel); importSection.appendChild(importTA); importSection.appendChild(restoreBtn);
  box.appendChild(importSection);
}

